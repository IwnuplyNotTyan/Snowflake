{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Xresources Dark",
  "author": "you",
  "themes": [
    {
      "name": "Xresources Dark",
      "appearance": "dark",
      "style": {
        "background": "#0B0F10",
        "elevated_surface.background": "#101415",
        "surface.background": "#101415",
        "panel.background": "#101415",

        "border": "#131718",
        "border.variant": "#131718",
        "border.focused": "#6791c9",
        "border.selected": "#6791c9",
        "border.transparent": "#00000000",
        "border.disabled": "#131718",

        "text": "#c5c8c9",
        "text.muted": "#7fc8db",
        "text.placeholder": "#7ba5dd",
        "text.disabled": "#c4c4c4",
        "text.accent": "#6791c9",

        "icon": "#c5c8c9",
        "icon.muted": "#c4c4c4",
        "icon.placeholder": "#c4c4c4",
        "icon.disabled": "#c4c4c4",
        "icon.accent": "#6791c9",

        "element.background": "#101415",
        "element.hover": "#131718",
        "element.active": "#131718",
        "element.selected": "#131718",
        "element.disabled": "#101415",
        "element.selected_hover": "#131718",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#131718",
        "ghost_element.active": "#131718",
        "ghost_element.selected": "#131718",
        "ghost_element.disabled": "#101415",
        "ghost_element.selected_hover": "#131718",

        "drop_target.background": "#6791c920",

        "selection.background": "#6791c940",
        "selection.cursor": "#c5c8c9",

        "scrollbar.thumb.background": "#131718",
        "scrollbar.thumb.hover_background": "#6791c9",
        "scrollbar.thumb.border": "#131718",
        "scrollbar.track.background": "#0B0F10",
        "scrollbar.track.border": "#131718",

        "status_bar.background": "#101415",
        "title_bar.background": "#101415",
        "title_bar.inactive_background": "#101415",
        "toolbar.background": "#0B0F10",
        "tab_bar.background": "#101415",
        "tab.inactive_background": "#101415",
        "tab.active_background": "#0B0F10",

        "search.match_background": "#de8f7840",

        "link_text.hover": "#7ba5dd",

        "conflict": "#bc83e3",
        "conflict.background": "#bc83e320",
        "conflict.border": "#bc83e3",
        "created": "#87c7a1",
        "created.background": "#87c7a120",
        "created.border": "#87c7a1",
        "deleted": "#df5b61",
        "deleted.background": "#df5b6120",
        "deleted.border": "#df5b61",
        "error": "#df5b61",
        "error.background": "#df5b6120",
        "error.border": "#df5b61",
        "hidden": "#c4c4c4",
        "hidden.background": "#101415",
        "hidden.border": "#131718",
        "hint": "#7ba5dd",
        "hint.background": "#6791c920",
        "hint.border": "#6791c9",
        "ignored": "#c4c4c4",
        "ignored.background": "#101415",
        "ignored.border": "#131718",
        "info": "#6791c9",
        "info.background": "#6791c920",
        "info.border": "#6791c9",
        "modified": "#de8f78",
        "modified.background": "#de8f7820",
        "modified.border": "#de8f78",
        "predictive": "#c4c4c4",
        "predictive.background": "#101415",
        "predictive.border": "#131718",
        "renamed": "#70b9cc",
        "renamed.background": "#70b9cc20",
        "renamed.border": "#70b9cc",
        "success": "#87c7a1",
        "success.background": "#87c7a120",
        "success.border": "#87c7a1",
        "unreachable": "#c4c4c4",
        "unreachable.background": "#101415",
        "unreachable.border": "#131718",
        "warning": "#de8f78",
        "warning.background": "#de8f7820",
        "warning.border": "#de8f78",

        "players": [
          { "cursor": "#c5c8c9", "background": "#6791c940", "selection": "#6791c930" },
          { "cursor": "#87c7a1", "background": "#87c7a140", "selection": "#87c7a130" },
          { "cursor": "#bc83e3", "background": "#bc83e340", "selection": "#bc83e330" },
          { "cursor": "#70b9cc", "background": "#70b9cc40", "selection": "#70b9cc30" },
          { "cursor": "#de8f78", "background": "#de8f7840", "selection": "#de8f7830" },
          { "cursor": "#df5b61", "background": "#df5b6140", "selection": "#df5b6130" },
          { "cursor": "#6791c9", "background": "#6791c940", "selection": "#6791c930" },
          { "cursor": "#7ba5dd", "background": "#7ba5dd40", "selection": "#7ba5dd30" }
        ],

        "terminal.background": "#0B0F10",
        "terminal.foreground": "#c5c8c9",
        "terminal.bright_foreground": "#cccccc",
        "terminal.dim_foreground": "#c4c4c4",
        "terminal.ansi.black": "#101415",
        "terminal.ansi.bright_black": "#131718",
        "terminal.ansi.red": "#df5b61",
        "terminal.ansi.bright_red": "#ee6a70",
        "terminal.ansi.green": "#87c7a1",
        "terminal.ansi.bright_green": "#96d6b0",
        "terminal.ansi.yellow": "#de8f78",
        "terminal.ansi.bright_yellow": "#ffb29b",
        "terminal.ansi.blue": "#6791c9",
        "terminal.ansi.bright_blue": "#7ba5dd",
        "terminal.ansi.magenta": "#bc83e3",
        "terminal.ansi.bright_magenta": "#cb92f2",
        "terminal.ansi.cyan": "#70b9cc",
        "terminal.ansi.bright_cyan": "#7fc8db",
        "terminal.ansi.white": "#c4c4c4",
        "terminal.ansi.bright_white": "#cccccc",

        "syntax": {
          "attribute":            { "color": "#de8f78" },
          "boolean":              { "color": "#bc83e3" },
          "comment":              { "color": "#c4c4c4", "font_style": "italic" },
          "comment.doc":          { "color": "#c4c4c4", "font_style": "italic" },
          "constant":             { "color": "#bc83e3" },
          "constructor":          { "color": "#70b9cc" },
          "embedded":             { "color": "#c5c8c9" },
          "emphasis":             { "color": "#c5c8c9", "font_style": "italic" },
          "emphasis.strong":      { "color": "#c5c8c9", "font_weight": 700 },
          "enum":                 { "color": "#de8f78" },
          "function":             { "color": "#87c7a1" },
          "function.builtin":     { "color": "#96d6b0" },
          "function.decorator":   { "color": "#de8f78" },
          "hint":                 { "color": "#c4c4c4", "font_weight": 700 },
          "keyword":              { "color": "#df5b61" },
          "keyword.control":      { "color": "#ee6a70" },
          "label":                { "color": "#70b9cc" },
          "link_text":            { "color": "#6791c9", "font_style": "italic" },
          "link_uri":             { "color": "#70b9cc" },
          "number":               { "color": "#bc83e3" },
          "operator":             { "color": "#70b9cc" },
          "predictive":           { "color": "#c4c4c4", "font_style": "italic" },
          "preproc":              { "color": "#df5b61" },
          "primary":              { "color": "#c5c8c9" },
          "property":             { "color": "#6791c9" },
          "punctuation":          { "color": "#c5c8c9" },
          "punctuation.bracket":  { "color": "#c5c8c9" },
          "punctuation.delimiter":{ "color": "#c5c8c9" },
          "punctuation.list_marker": { "color": "#df5b61" },
          "punctuation.special":  { "color": "#70b9cc" },
          "string":               { "color": "#de8f78" },
          "string.escape":        { "color": "#70b9cc" },
          "string.regex":         { "color": "#70b9cc" },
          "string.special":       { "color": "#70b9cc" },
          "string.special.symbol":{ "color": "#bc83e3" },
          "tag":                  { "color": "#df5b61" },
          "text.literal":         { "color": "#de8f78" },
          "title":                { "color": "#6791c9", "font_weight": 700 },
          "type":                 { "color": "#70b9cc" },
          "type.builtin":         { "color": "#7fc8db" },
          "variable":             { "color": "#c5c8c9" },
          "variable.builtin":     { "color": "#ee6a70" },
          "variable.member":      { "color": "#6791c9" },
          "variable.parameter":   { "color": "#ffb29b" },
          "variable.special":     { "color": "#df5b61" },
          "variant":              { "color": "#bc83e3" }
        }
      }
    }
  ]
}
